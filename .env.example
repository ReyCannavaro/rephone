NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Server only. Never expose this value to client components.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional local/dev helpers.
# Used by Supabase CLI type generation when you choose --db-url.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_PROJECT_ID=your-project-ref
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth role setup:
# Set the owner's Supabase Auth user app_metadata.role to "OWNER".
# Example in Supabase SQL editor:
# update auth.users set raw_app_meta_data = raw_app_meta_data || '{"role":"OWNER"}'::jsonb where email = 'owner@example.com';

# Development checklist:
# 1. Apply supabase/schema.sql in Supabase SQL Editor.
# 2. Optional: apply supabase/dev-seed.sql for demo data.
# 3. Run npm run quality before pushing changes.
